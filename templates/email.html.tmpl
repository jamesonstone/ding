<!doctype html>
<html>
<body style="margin:0;padding:0;background:#f4f4f5;font-family:Arial,Helvetica,sans-serif;color:#1f2937;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5;padding:24px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="640" cellpadding="0" cellspacing="0" style="background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
          <tr>
            <td style="padding:24px 28px;background:#111827;color:#ffffff;font-size:20px;font-weight:bold;">
              🔔 Invoice status — {{.Month}} {{.Year}}
            </td>
          </tr>
          <tr>
            <td style="padding:24px 28px;">
              <p style="margin:0 0 16px 0;font-size:15px;">Hi {{.CustomerName}},</p>
              <p style="margin:0 0 20px 0;font-size:15px;">Here is your current invoice summary. Outstanding balances are grouped by the month each invoice was issued.</p>
              {{range .Months}}
              <p style="margin:20px 0 6px 0;font-size:13px;font-weight:bold;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;">{{.Label}}</p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;font-size:13px;">
                <tr style="background:#f9fafb;color:#374151;">
                  <th align="left" style="padding:8px 10px;border-bottom:2px solid #e5e7eb;">Invoice</th>
                  <th align="left" style="padding:8px 10px;border-bottom:2px solid #e5e7eb;">Issued</th>
                  <th align="left" style="padding:8px 10px;border-bottom:2px solid #e5e7eb;">Due</th>
                  <th align="right" style="padding:8px 10px;border-bottom:2px solid #e5e7eb;">Amount</th>
                  <th align="left" style="padding:8px 10px;border-bottom:2px solid #e5e7eb;">Status</th>
                  <th align="right" style="padding:8px 10px;border-bottom:2px solid #e5e7eb;">Days Late</th>
                  <th align="right" style="padding:8px 10px;border-bottom:2px solid #e5e7eb;">Outstanding</th>
                </tr>
                {{range .Invoices}}
                <tr{{if .Late}} style="background:#fdf2f2;border-left:3px solid #d9534f;"{{end}}>
                  <td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;{{if .Late}}color:#d9534f;font-weight:bold;{{end}}">{{.ID}}</td>
                  <td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;">{{.Issued}}</td>
                  <td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;">{{.Due}}</td>
                  <td align="right" style="padding:8px 10px;border-bottom:1px solid #f3f4f6;">{{.Amount}}</td>
                  <td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;">{{.Status}}</td>
                  <td align="right" style="padding:8px 10px;border-bottom:1px solid #f3f4f6;{{if .Late}}color:#d9534f;font-weight:bold;{{end}}">{{.DaysLate}}</td>
                  <td align="right" style="padding:8px 10px;border-bottom:1px solid #f3f4f6;">{{.Outstanding}}</td>
                </tr>
                {{end}}
                <tr>
                  <td colspan="6" align="right" style="padding:8px 10px;font-size:12px;color:#6b7280;">{{.Label}} subtotal</td>
                  <td align="right" style="padding:8px 10px;font-size:12px;color:#6b7280;">{{.MonthTotal}}</td>
                </tr>
              </table>
              {{end}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin-top:18px;">
                <tr style="background:#111827;color:#ffffff;">
                  <td style="padding:12px 10px;font-weight:bold;font-size:14px;">Total outstanding</td>
                  <td align="right" style="padding:12px 10px;font-weight:bold;font-size:14px;">{{.TotalOutstanding}}</td>
                </tr>
              </table>
              <p style="margin:24px 0 0 0;font-size:14px;">Thanks,<br>{{.SenderName}}</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
